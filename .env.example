NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
# Current MCP-created project ref: cvjvreasqbnhcnwstwyq (region ap-southeast-1)

# Bắt buộc cho đăng nhập dashboard: JWT ký session (tối thiểu 16 ký tự). openssl rand -base64 32
WA_SESSION_SECRET=
# Tuổi session giây (300–2592000), mặc định 7 ngày
# WA_SESSION_TTL_SEC=604800

# Khuyến nghị production: pepper hash license key trong DB (cùng độ dài tối thiểu). Có thể trùng WA_SESSION_SECRET nếu cần gọn.
# LICENSE_KEY_PEPPER=

# Chỉ mock mode (không Supabase): mật khẩu owner trong lib/mock-data — không dùng trên production
# DEV_MOCK_ADMIN_PASSWORD=

# Optional: short-lived JWT after /api/licenses/verify — client refreshes via POST /api/licenses/session (harder to fake than a single bool patch).
# Generate: openssl rand -base64 32
LICENSE_SESSION_SECRET=
# Session TTL seconds (300–86400), default 3600
# LICENSE_SESSION_TTL_SEC=3600
